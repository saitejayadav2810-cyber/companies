const platClass = {
  "BigBasket":"plat-bb","Blinkit":"plat-bk","Zepto":"plat-zp",
  "Swiggy Instamart":"plat-si","JioMart":"plat-jm","Amazon":"plat-am","D2C":"plat-d2c"
};

function renderCard(b, delay) {
  const typeTags = b.types.map(t => `<span class="tag tag-${t}">${t}</span>`).join('');
  const platTags = b.platforms.map(p => `<span class="plat ${platClass[p]||''}">${p}</span>`).join('');
  return `<div class="card" style="animation-delay:${delay}ms">
    <div class="card-header">
      <div class="brand-name">${b.name}</div>
      <span class="sno">#${b.sno}</span>
    </div>
    <div class="hq">
      <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
      ${b.hq}
    </div>
    <div class="products"><strong>Products</strong>${b.products}</div>
    ${typeTags ? `<div class="tags">${typeTags}</div>` : ''}
    <div class="platforms">${platTags}</div>
  </div>`;
}

function filter() {
  const q = document.getElementById('search').value.toLowerCase();
  const plat = document.getElementById('platform').value;
  const type = document.getElementById('type').value;
  const results = brands.filter(b => {
    const text = `${b.name} ${b.products} ${b.hq}`.toLowerCase();
    const matchQ = !q || text.includes(q);
    const matchP = !plat || b.platforms.some(p => p === plat || (plat === 'Amazon' && p.startsWith('Amazon')));
    const matchT = !type || b.types.includes(type);
    return matchQ && matchP && matchT;
  });
  const grid = document.getElementById('grid');
  document.getElementById('countLabel').innerHTML = `Showing <strong>${results.length}</strong> of ${brands.length} brands`;
  if (!results.length) {
    grid.innerHTML = `<div class="no-results"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><p>No brands match your filters.</p></div>`;
    return;
  }
  grid.innerHTML = results.map((b,i) => renderCard(b, Math.min(i*20,300))).join('');
}

filter();
